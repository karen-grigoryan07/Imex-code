        in case of policy->insured_person->addresses->location_type_id == 1 {
            in case of policy->insured_person->addresses->location1_id == "7" {
                variable actions = array("ASWA_GEGHARKUNIK_BM9"); 
                variable actions = array_push(actions,"CORRECTION");
